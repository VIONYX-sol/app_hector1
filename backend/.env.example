# ══════════════════════════════════════════════════════════════════════════════
# VENUE RESERVATION BACKEND - ENVIRONMENT VARIABLES
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values

# ──────────────────────────────────────────────────────────────────────────────
# Server Configuration
# ──────────────────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=3001

# CORS - comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ──────────────────────────────────────────────────────────────────────────────
# Database Configuration (PostgreSQL)
# ──────────────────────────────────────────────────────────────────────────────

DATABASE_URL=postgresql://user:password@localhost:5432/venue_reservations
DB_POOL_MIN=2
DB_POOL_MAX=20

# ──────────────────────────────────────────────────────────────────────────────
# Security
# ──────────────────────────────────────────────────────────────────────────────

# JWT secret for legacy auth (if needed)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# ──────────────────────────────────────────────────────────────────────────────
# Admin User Setup (for seeding)
# ──────────────────────────────────────────────────────────────────────────────

# Run: npm run seed
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-secure-password-min-8-chars
ADMIN_USERNAME=admin

# ──────────────────────────────────────────────────────────────────────────────
# Microsoft Graph Email Configuration
# ──────────────────────────────────────────────────────────────────────────────

# Azure AD App Registration
MS_GRAPH_TENANT_ID=your-tenant-id
MS_GRAPH_CLIENT_ID=your-client-id
MS_GRAPH_CLIENT_SECRET=your-client-secret

# Email settings
MS_GRAPH_SENDER_EMAIL=notifications@yourdomain.com
NOTIFICATION_TO_EMAIL=owner@yourdomain.com
SEND_CUSTOMER_ACK_EMAIL=false

# Admin panel URL (for email links)
ADMIN_URL=https://yourdomain.com/admin

# ──────────────────────────────────────────────────────────────────────────────
# Optional: SMTP Configuration (alternative to Microsoft Graph)
# ──────────────────────────────────────────────────────────────────────────────

# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user
# SMTP_PASS=password
# FROM_NAME=Venue Manager
# FROM_EMAIL=noreply@example.com
