    "express-validator": "^7.0.1",
    "multer": "^2.1.1",
    "nodemailer": "^7.0.11",
    "winston": "^3.11.0",
    "dotenv": "^16.4.1",
    "uuid": "^9.0.1",
    "speakeasy": "^2.0.0",
    "qrcode": "^1.5.3",
    "stripe": "^14.14.0",
    "axios": "^1.6.7",
    "express-mongo-sanitize": "^2.2.0",
    "hpp": "^0.2.3",
    "xss": "^1.0.15",
    "joi": "^17.12.1",
    "compression": "^1.7.4",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.3",
    "jest": "^29.7.0",
