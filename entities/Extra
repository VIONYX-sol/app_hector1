{
  "name": "Extra",
  "type": "object",
  "properties": {
    "company_id": {
      "type": "string"
    },
    "room_id": {
      "type": "string",
      "description": "Optional, if room-specific"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "price": {
      "type": "number"
    },
    "type": {
      "type": "string",
      "enum": [
        "per_booking",
        "per_hour",
        "per_person"
      ],
      "default": "per_booking"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "inactive"
      ],
      "default": "active"
    }
  },
  "required": [
    "name",
    "price",
    "company_id"
  ]
}