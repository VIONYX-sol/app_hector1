{
  "name": "Company",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Business name"
    },
    "legal_name": {
      "type": "string",
      "description": "Legal/fiscal name"
    },
    "nif": {
      "type": "string",
      "description": "NIF/CIF"
    },
    "logo_url": {
      "type": "string",
      "description": "Logo image URL"
    },
    "description": {
      "type": "string",
      "description": "Business description"
    },
    "address": {
      "type": "string"
    },
    "city": {
      "type": "string"
    },
    "postal_code": {
      "type": "string"
    },
    "province": {
      "type": "string"
    },
    "country": {
      "type": "string",
      "default": "Espa\u00f1a"
    },
    "phone": {
      "type": "string"
    },
    "email": {
      "type": "string"
    },
    "website": {
      "type": "string"
    },
    "mode": {
      "type": "string",
      "enum": [
        "single_room",
        "multi_room"
      ],
      "default": "multi_room"
    },
    "currency": {
      "type": "string",
      "default": "EUR"
    },
    "timezone": {
      "type": "string",
      "default": "Europe/Madrid"
    },
    "primary_color": {
      "type": "string",
      "default": "#2563eb"
    },
    "opening_hours": {
      "type": "string",
      "description": "JSON string with opening hours"
    },
    "hero_image": {
      "type": "string",
      "description": "URL de imagen del hero de la portada"
    },
    "stat1_value": {
      "type": "string",
      "description": "Valor m\u00e9trica 1 del hero"
    },
    "stat1_label": {
      "type": "string",
      "description": "Etiqueta m\u00e9trica 1 del hero"
    },
    "stat2_value": {
      "type": "string",
      "description": "Valor m\u00e9trica 2 del hero"
    },
    "stat2_label": {
      "type": "string",
      "description": "Etiqueta m\u00e9trica 2 del hero"
    },
    "stat3_value": {
      "type": "string",
      "description": "Valor m\u00e9trica 3 del hero"
    },
    "stat3_label": {
      "type": "string",
      "description": "Etiqueta m\u00e9trica 3 del hero"
    },
    "social_instagram": {
      "type": "string"
    },
    "social_facebook": {
      "type": "string"
    },
    "social_linkedin": {
      "type": "string"
    },
    "seo_title": {
      "type": "string"
    },
    "seo_description": {
      "type": "string"
    },
    "seo_image": {
      "type": "string"
    },
    "terms_url": {
      "type": "string"
    },
    "privacy_url": {
      "type": "string"
    },
    "cancellation_policy_text": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "inactive",
        "setup"
      ],
      "default": "setup"
    }
  },
  "required": [
    "name"
  ]
}