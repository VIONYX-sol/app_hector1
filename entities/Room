{
  "name": "Room",
  "type": "object",
  "properties": {
    "company_id": {
      "type": "string",
      "description": "Company ID"
    },
    "name": {
      "type": "string"
    },
    "slug": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "short_description": {
      "type": "string"
    },
    "images": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Array of image URLs"
    },
    "capacity_min": {
      "type": "number",
      "default": 1
    },
    "capacity_max": {
      "type": "number"
    },
    "size_sqm": {
      "type": "number",
      "description": "Size in square meters"
    },
    "equipment": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of equipment"
    },
    "services": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of services"
    },
    "rules": {
      "type": "string",
      "description": "Room rules"
    },
    "price_per_hour": {
      "type": "number"
    },
    "price_per_half_day": {
      "type": "number"
    },
    "price_per_day": {
      "type": "number"
    },
    "deposit_required": {
      "type": "boolean",
      "default": true
    },
    "deposit_type": {
      "type": "string",
      "enum": [
        "fixed",
        "percentage"
      ],
      "default": "percentage"
    },
    "deposit_amount": {
      "type": "number",
      "description": "Fixed amount or percentage"
    },
    "deposit_deadline_hours": {
      "type": "number",
      "default": 24,
      "description": "Hours to pay deposit"
    },
    "buffer_minutes": {
      "type": "number",
      "default": 15,
      "description": "Buffer between bookings"
    },
    "min_booking_hours": {
      "type": "number",
      "default": 1
    },
    "max_booking_hours": {
      "type": "number",
      "default": 12
    },
    "available_from": {
      "type": "string",
      "default": "09:00"
    },
    "available_to": {
      "type": "string",
      "default": "22:00"
    },
    "available_days": {
      "type": "array",
      "items": {
        "type": "number"
      },
      "description": "0=Sun,1=Mon,...6=Sat"
    },
    "cancellation_full_refund_days": {
      "type": "number",
      "default": 7
    },
    "cancellation_partial_refund_days": {
      "type": "number",
      "default": 3
    },
    "cancellation_partial_refund_percent": {
      "type": "number",
      "default": 50
    },
    "seo_title": {
      "type": "string"
    },
    "seo_description": {
      "type": "string"
    },
    "sort_order": {
      "type": "number",
      "default": 0
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "inactive",
        "maintenance"
      ],
      "default": "active"
    }
  },
  "required": [
    "name",
    "company_id"
  ]
}