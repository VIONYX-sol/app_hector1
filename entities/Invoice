{
  "name": "Invoice",
  "type": "object",
  "properties": {
    "company_id": {
      "type": "string"
    },
    "reservation_id": {
      "type": "string"
    },
    "customer_id": {
      "type": "string"
    },
    "payment_id": {
      "type": "string"
    },
    "invoice_number": {
      "type": "string"
    },
    "series": {
      "type": "string",
      "default": "F"
    },
    "type": {
      "type": "string",
      "enum": [
        "deposit",
        "final",
        "rectificative",
        "refund"
      ],
      "default": "final"
    },
    "issue_date": {
      "type": "string",
      "format": "date"
    },
    "due_date": {
      "type": "string",
      "format": "date"
    },
    "issuer_name": {
      "type": "string"
    },
    "issuer_nif": {
      "type": "string"
    },
    "issuer_address": {
      "type": "string"
    },
    "customer_name": {
      "type": "string"
    },
    "customer_nif": {
      "type": "string"
    },
    "customer_address": {
      "type": "string"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "description": {
            "type": "string"
          },
          "quantity": {
            "type": "number"
          },
          "unit_price": {
            "type": "number"
          },
          "tax_rate": {
            "type": "number"
          },
          "total": {
            "type": "number"
          }
        }
      }
    },
    "subtotal": {
      "type": "number"
    },
    "tax_amount": {
      "type": "number"
    },
    "total": {
      "type": "number"
    },
    "currency": {
      "type": "string",
      "default": "EUR"
    },
    "pdf_url": {
      "type": "string"
    },
    "hash": {
      "type": "string",
      "description": "Integrity hash for VERI*FACTU"
    },
    "previous_hash": {
      "type": "string"
    },
    "qr_data": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    },
    "fiscal_status": {
      "type": "string",
      "enum": [
        "draft",
        "ready_to_issue",
        "issued",
        "cancelled",
        "rectified"
      ],
      "default": "draft"
    },
    "aeat_status": {
      "type": "string",
      "enum": [
        "pending",
        "sending",
        "accepted",
        "rejected",
        "retry_scheduled"
      ],
      "default": "pending"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "issued",
        "paid",
        "cancelled"
      ],
      "default": "draft"
    }
  },
  "required": [
    "company_id",
    "invoice_number"
  ]
}