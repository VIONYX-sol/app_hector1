{
  "name": "Expense",
  "type": "object",
  "properties": {
    "company_id": {
      "type": "string"
    },
    "room_id": {
      "type": "string",
      "description": "Optional room association"
    },
    "title": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": [
        "electricity",
        "water",
        "rent",
        "internet",
        "maintenance",
        "cleaning",
        "insurance",
        "taxes",
        "supplies",
        "marketing",
        "software",
        "other"
      ],
      "default": "other"
    },
    "supplier": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "due_date": {
      "type": "string",
      "format": "date"
    },
    "amount": {
      "type": "number"
    },
    "tax_amount": {
      "type": "number"
    },
    "total": {
      "type": "number"
    },
    "document_url": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    },
    "recurring": {
      "type": "boolean",
      "default": false
    },
    "recurring_period": {
      "type": "string",
      "enum": [
        "monthly",
        "quarterly",
        "yearly"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "paid",
        "overdue",
        "cancelled"
      ],
      "default": "pending"
    }
  },
  "required": [
    "title",
    "amount",
    "company_id"
  ]
}