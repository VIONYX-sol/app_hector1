{
  "name": "Customer",
  "type": "object",
  "properties": {
    "company_id": {
      "type": "string"
    },
    "user_id": {
      "type": "string",
      "description": "Linked user account ID"
    },
    "full_name": {
      "type": "string"
    },
    "email": {
      "type": "string"
    },
    "email_canonical": {
      "type": "string",
      "description": "Normalized email for dedup"
    },
    "phone": {
      "type": "string"
    },
    "nif": {
      "type": "string",
      "description": "Tax ID for invoicing"
    },
    "fiscal_name": {
      "type": "string"
    },
    "fiscal_address": {
      "type": "string"
    },
    "fiscal_city": {
      "type": "string"
    },
    "fiscal_postal_code": {
      "type": "string"
    },
    "fiscal_province": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    },
    "total_spent": {
      "type": "number",
      "default": 0
    },
    "total_bookings": {
      "type": "number",
      "default": 0
    },
    "total_cancellations": {
      "type": "number",
      "default": 0
    },
    "last_booking_date": {
      "type": "string",
      "format": "date-time"
    },
    "score": {
      "type": "number",
      "default": 50,
      "description": "Client score 0-100"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "inactive",
        "blocked"
      ],
      "default": "active"
    }
  },
  "required": [
    "email",
    "company_id"
  ]
}