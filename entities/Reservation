{
  "name": "Reservation",
  "type": "object",
  "properties": {
    "company_id": {
      "type": "string"
    },
    "room_id": {
      "type": "string"
    },
    "customer_id": {
      "type": "string"
    },
    "room_name": {
      "type": "string"
    },
    "customer_name": {
      "type": "string"
    },
    "customer_email": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "start_time": {
      "type": "string",
      "description": "HH:MM"
    },
    "end_time": {
      "type": "string",
      "description": "HH:MM"
    },
    "duration_hours": {
      "type": "number"
    },
    "attendees": {
      "type": "number"
    },
    "event_type": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    },
    "subtotal": {
      "type": "number"
    },
    "extras_total": {
      "type": "number",
      "default": 0
    },
    "tax_rate": {
      "type": "number",
      "default": 21
    },
    "tax_amount": {
      "type": "number"
    },
    "total_amount": {
      "type": "number"
    },
    "deposit_amount": {
      "type": "number"
    },
    "deposit_paid": {
      "type": "boolean",
      "default": false
    },
    "deposit_paid_date": {
      "type": "string",
      "format": "date-time"
    },
    "balance_amount": {
      "type": "number"
    },
    "balance_paid": {
      "type": "boolean",
      "default": false
    },
    "balance_paid_date": {
      "type": "string",
      "format": "date-time"
    },
    "deposit_deadline": {
      "type": "string",
      "format": "date-time"
    },
    "cancellation_date": {
      "type": "string",
      "format": "date-time"
    },
    "cancellation_reason": {
      "type": "string"
    },
    "refund_amount": {
      "type": "number"
    },
    "extras": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "price": {
            "type": "number"
          },
          "quantity": {
            "type": "number"
          }
        }
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "temporal_block",
        "pending_deposit",
        "confirmed",
        "paid",
        "in_progress",
        "completed",
        "cancelled",
        "expired",
        "no_show"
      ],
      "default": "temporal_block"
    }
  },
  "required": [
    "company_id",
    "room_id",
    "date",
    "start_time",
    "end_time"
  ]
}